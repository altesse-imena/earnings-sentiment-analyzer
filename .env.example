# No API keys required for SEC EDGAR or yfinance
# Add any optional keys below if extending the project

# Optional: Alpha Vantage for additional price data
# ALPHA_VANTAGE_API_KEY=your_key_here

# Cache directory (defaults to data/raw/cache)
CACHE_DIR=data/raw/cache

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
